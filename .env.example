# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=addruser
POSTGRES_PASSWORD=addrpass
POSTGRES_DB=address_db

# ─── NestJS Backend ───────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=addruser
DATABASE_PASSWORD=addrpass
DATABASE_NAME=address_db
REDIS_HOST=localhost
REDIS_PORT=6379
ML_SERVICE_URL=http://localhost:8000

# ─── Confidence Thresholds ───────────────────────────────────────────────────
AUTO_ACCEPT_THRESHOLD=0.80
REVIEW_THRESHOLD=0.50
RETRAIN_TRIGGER_COUNT=50

# ─── Python ML Service ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://addruser:addrpass@localhost:5432/address_db
MODEL_PATH=./models/lgbm_model.pkl
EMBEDDING_MODEL=all-MiniLM-L6-v2
LOG_LEVEL=INFO
